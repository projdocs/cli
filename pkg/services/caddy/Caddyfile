{$PROXY_DOMAIN} {
    @supabase_api path /auth/v1/* /rest/v1/* /graphql/v1 /realtime/v1/* /storage/v1/* /functions/v1/* /mcp /sso/*
    handle @supabase_api {
        reverse_proxy kong:8000
    }
    handle {
        respond 403
    }
    header -server
}

{$WEB_DOMAIN} {
    handle {
        reverse_proxy web:3000
    }
    header -server
}